# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables / secrets
.env
*.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/

# Raw dataset & archives — too large for git (~3.3 GB zip / ~4.2 GB extracted).
# Downloaded from Kaggle via scripts/download_dataset.sh, never committed.
# archive/README.md is force-added (git add -f) so the download instructions
# stay tracked even though the folder itself is ignored.
archive/
.archive/
.archive
*.zip

# Data (uncomment if your data shouldn't be tracked)
# data/

# Logs
*.log

# Claude config
.claude/

# Code council (if it's a tool/skill dir, not your actual project code)
code-council/

# p10 coding-rules skill — tooling dropped into the repo, not project code
# (same rationale as code-council/ above).
.p10-skill/

# Ephemeral stdout captures from training/app launches. The structured
# per-epoch metric logs (logs/*.jsonl) ARE committed; these .out dumps are not.
logs/*.out

# Whole-slide pipeline smoke-test outputs (regenerated by src/wsi_inference.py).
logs/wsi_*/

# Generated valid-patch manifest cache (~13MB). Auto-rebuilt by src/data.py
# (load_manifest) whenever absent/stale, and only usable when archive/ is
# present — which is itself untracked. The canonical patient->split assignment
# lives in the small, committed data/splits.json.
data/manifest.json